{
  "name": "@cryptoapis-io/mcp-contracts",
  "version": "0.2.0",
  "description": "MCP server for reading smart contract ABIs and on-chain data from EVM and Solana blockchains via Crypto APIs",
  "license": "MIT",
  "author": "Crypto APIs, Inc.",
  "repository": {
    "type": "git",
    "url": "https://github.com/CryptoAPIs-io/cryptoapis-mcp-contracts.git"
  },
  "keywords": [
    "mcp",
    "cryptoapis",
    "blockchain",
    "smart-contracts",
    "evm",
    "solana"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "bin": {
    "cryptoapis-mcp-contracts": "dist/cli.js"
  },
  "dependencies": {
    "@cryptoapis-io/mcp-shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.25.1",
    "express": "^4.19.2",
    "zod": "^3.25.0"
  },
  "scripts": {
    "dev": "tsx watch src/cli.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "node -e \"console.log('lint: add eslint if you want')\"",
    "test": "node -e \"console.log('test: add later')\"",
    "clean": "rimraf dist"
  },
  "devDependencies": {
    "@types/express": "^5.0.6"
  }
}
